# ---------------------------------------------------------------------------
# f1-pitwall environment variables
# Copy to `.env` and fill in as needed. All values are OPTIONAL for Phase 1 —
# the dashboard renders from committed static JSON with no secrets required.
# ---------------------------------------------------------------------------

# --- Web dashboard (apps/web) ---------------------------------------------
# Base URL the dashboard/widget uses when building absolute data URLs.
# Leave empty for same-origin (recommended on Vercel).
NEXT_PUBLIC_DATA_BASE_URL=

# Public URL of the deployed dashboard, used in docs/widget examples.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Python data pipeline (python/f1pitwall) ------------------------------
# Directory FastF1 uses to cache downloaded session telemetry. Kept out of git.
FASTF1_CACHE_DIR=./python/.fastf1-cache

# Where the pipeline writes generated JSON (the committed source of truth).
PUBLIC_DATA_DIR=./public-data

# Optional: OpenWeatherMap key for the (later) prediction weather features.
# Not used in Phase 1. https://openweathermap.org/api
OPENWEATHER_API_KEY=
