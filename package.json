{
  "name": "f1-pitwall",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial F1 race-replay + prediction portfolio project: FastF1 data pipeline, replayable JSON, and a polished Next.js dashboard.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "pnpm --filter @f1pitwall/web dev",
    "build": "pnpm -r --filter=./packages/* build && pnpm --filter @f1pitwall/web build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0"
  }
}
